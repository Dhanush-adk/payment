{
  "openapi": "3.0.3",
  "info": {
    "title": "Payment API (India)",
    "description": "Payment processing API for India – UPI, cards, net banking, wallets, cash on delivery. TrendRush-style schema (raw MySQL).",
    "version": "1.0.0",
    "contact": { "name": "API Support" }
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Local" }
  ],
  "tags": [
    { "name": "Payments", "description": "Create, confirm, status, refund" },
    { "name": "Orders", "description": "Create and manage orders" },
    { "name": "GST", "description": "GST calculation and validation" },
    { "name": "Webhooks", "description": "Razorpay and generic webhooks" }
  ],
  "paths": {
    "/api/payments/methods": {
      "get": {
        "tags": ["Payments"],
        "summary": "Get supported payment methods",
        "responses": {
          "200": {
            "description": "List of methods",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": { "type": "array", "items": { "type": "object" } },
                    "country": { "type": "string", "example": "India" },
                    "currency": { "type": "string", "example": "INR" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/payments/create": {
      "post": {
        "tags": ["Payments"],
        "summary": "Create payment",
        "description": "Creates payment (TrendRush schema). Requires order to exist in norders and billing/shipping addressId.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount", "currency", "paymentMethod", "orderId", "userId", "customerPhone", "billingAddress", "shippingAddress"],
                "properties": {
                  "amount": { "type": "number", "example": 100 },
                  "currency": { "type": "string", "example": "INR" },
                  "paymentMethod": { "type": "string", "enum": ["upi", "card", "netbanking", "wallet", "cash_on_delivery"] },
                  "orderId": { "type": "string", "description": "Order number (e.g. ORD_...) or numeric order_id" },
                  "userId": { "type": "string" },
                  "customerPhone": { "type": "string", "example": "+919876543210" },
                  "customerEmail": { "type": "string" },
                  "customerName": { "type": "string" },
                  "billingAddress": {
                    "type": "object",
                    "required": ["addressId"],
                    "properties": {
                      "addressId": { "type": "integer" },
                      "state": { "type": "string" }
                    }
                  },
                  "shippingAddress": {
                    "type": "object",
                    "required": ["addressId"],
                    "properties": {
                      "addressId": { "type": "integer" },
                      "state": { "type": "string" }
                    }
                  },
                  "items": { "type": "array", "items": { "type": "object", "properties": { "name": {}, "quantity": {}, "price": {} } } },
                  "gstNumber": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Payment created" },
          "400": { "description": "Validation or business error" }
        }
      }
    },
    "/api/payments/confirm": {
      "post": {
        "tags": ["Payments"],
        "summary": "Confirm payment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["paymentId", "paymentMethod"],
                "properties": {
                  "paymentId": { "type": "integer" },
                  "paymentMethod": { "type": "string", "enum": ["upi", "card", "netbanking", "wallet", "cash_on_delivery"] },
                  "paymentData": {
                    "type": "object",
                    "properties": {
                      "razorpayOrderId": { "type": "string" },
                      "razorpayPaymentId": { "type": "string" },
                      "razorpaySignature": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment confirmed" },
          "400": { "description": "Verification failed" },
          "404": { "description": "Payment not found" }
        }
      }
    },
    "/api/payments/status/{paymentId}": {
      "get": {
        "tags": ["Payments"],
        "summary": "Get payment status",
        "parameters": [
          { "name": "paymentId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Payment details and status" },
          "404": { "description": "Payment not found" }
        }
      }
    },
    "/api/payments/refund": {
      "post": {
        "tags": ["Payments"],
        "summary": "Refund payment",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["paymentId"],
                "properties": {
                  "paymentId": { "type": "integer" },
                  "amount": { "type": "number", "description": "Optional; full amount if omitted" },
                  "reason": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Refund processed" },
          "400": { "description": "Only completed payments can be refunded" },
          "404": { "description": "Payment not found" }
        }
      }
    },
    "/api/orders/create": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create order",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["userId", "items", "totalAmount", "shippingAddress", "billingAddress"],
                "properties": {
                  "userId": { "type": "string" },
                  "items": {
                    "type": "array",
                    "items": { "type": "object", "properties": { "name": {}, "quantity": {}, "price": {} } }
                  },
                  "totalAmount": { "type": "number" },
                  "shippingAddress": { "type": "object" },
                  "billingAddress": { "type": "object" },
                  "paymentMethod": { "type": "string" },
                  "gstNumber": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created; returns orderId (order_number), order_id, shippingAddressId, billingAddressId"
          },
          "400": { "description": "Validation failed" }
        }
      }
    },
    "/api/orders/{orderId}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order by ID or order number",
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Order number (ORD_...) or numeric order_id" }
        ],
        "responses": {
          "200": { "description": "Order and payment (if any)" },
          "404": { "description": "Order not found" }
        }
      }
    },
    "/api/orders/user/{userId}": {
      "get": {
        "tags": ["Orders"],
        "summary": "List orders by user",
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": { "200": { "description": "Orders and pagination" } }
      }
    },
    "/api/orders/{orderId}/status": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Update order status",
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": { "status": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Status updated" } }
      }
    },
    "/api/orders/{orderId}/cancel": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Cancel order",
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "reason": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Order cancelled" } }
      }
    },
    "/api/gst/calculate": {
      "post": {
        "tags": ["GST"],
        "summary": "Calculate GST",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount"],
                "properties": {
                  "amount": { "type": "number" },
                  "gstRate": { "type": "number", "default": 18 },
                  "isInterState": { "type": "boolean", "default": false }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "GST breakdown" } }
      }
    },
    "/api/gst/rates": {
      "get": {
        "tags": ["GST"],
        "summary": "Get GST rate categories",
        "responses": { "200": { "description": "Rate list" } }
      }
    },
    "/api/gst/validate": {
      "post": {
        "tags": ["GST"],
        "summary": "Validate GST number",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["gstNumber"],
                "properties": { "gstNumber": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Valid/invalid" } }
      }
    },
    "/api/webhooks/razorpay": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Razorpay webhook (payment.captured, payment.failed, order.paid)",
        "responses": { "200": { "description": "Received" } }
      }
    },
    "/health": {
      "get": {
        "tags": [],
        "summary": "Health check",
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
